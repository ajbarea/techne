##
## techne starter Makefile — polyglot wrapper targets
##
## Pull via:
##   curl -fsSL https://raw.githubusercontent.com/ajbarea/techne/main/templates/Makefile.example -o Makefile
##
## Pair with scripts/dev-runner.sh so each invocation writes a
## logs/dev-<UTC>-<target>.log archive that techne:audit reconciles
## against the terminal exit code. See docs/conventions.md.
##
## Help convention: a `## description` comment after the target name is
## picked up by the help target below. Keep descriptions one line.
##

.PHONY: help setup fix lint test test-unit build validate ci audit clean docs dev
.DEFAULT_GOAL := help

# Replace DEV with the runner you actually use. Defaults to dev-runner.sh so
# every target archives by default; drop the prefix on a target you don't
# want archived (e.g. interactive servers, help).
DEV := ./scripts/dev-runner.sh

# Stack-specific invocations live behind dev-runner.sh, so this file stays
# the same shape across uv / npm / cargo / mixed repos. Examples for the
# body of each target (pick one, delete the rest):
#
#   uv:    uv sync --group dev      |  uv run pytest      |  uv run ruff check .
#   npm:   npm ci                   |  npm test           |  npm run lint
#   cargo: cargo fetch              |  cargo test --all   |  cargo clippy
#   pnpm:  pnpm install --frozen-lockfile  |  pnpm test   |  pnpm lint

setup:                  ## Install dependencies for the project
	@$(DEV) setup

fix:                    ## Run every auto-fixer; skip the check pass
	@$(DEV) fix

lint:                   ## Lint + format check (no auto-fix)
	@$(DEV) lint

test-unit:              ## Unit tests only (fast)
	@$(DEV) test-unit

test:                   ## Full test suite
	@$(DEV) test

build:                  ## Produce the deployable artifact
	@$(DEV) build

validate: lint test-unit build  ## Fast pre-push gate (lint + unit + build)

ci: lint test build     ## Mirror CI end-to-end

audit:                  ## Security audit (pip-audit / npm audit / cargo audit)
	@$(DEV) audit

clean:                  ## Remove build artifacts and caches
	@$(DEV) clean

# Interactive / long-running targets. Mark these under `do_not_run:` in
# .claude/skill-context.md so techne:audit skips them.
docs:                   ## Serve docs site locally (do-not-run)
	@$(DEV) docs

dev:                    ## Start dev server (do-not-run)
	@$(DEV) dev

help:                   ## Show this help
	@grep -hE '^[a-zA-Z][a-zA-Z0-9_-]*:.*?##' $(MAKEFILE_LIST) \
		| sort \
		| awk 'BEGIN {FS = ":.*?## "}; {printf "  %-12s %s\n", $$1, $$2}'
