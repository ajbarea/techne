##
## techne starter Makefile — polyglot wrapper targets
##
## Pull via:
##   curl -fsSL https://raw.githubusercontent.com/ajbarea/techne/main/templates/Makefile.example -o Makefile
##
## Replace each `TODO` target body with your stack's invocation. Common stacks:
##   uv:    `uv sync --group dev`           |  `uv run pytest`     |  `uv run ruff check . && uv run ruff format --check .`
##   npm:   `npm ci`                        |  `npm test`          |  `npm run lint`
##   cargo: `cargo fetch`                   |  `cargo test --all`  |  `cargo fmt --check && cargo clippy`
##   pnpm:  `pnpm install --frozen-lockfile`|  `pnpm test`         |  `pnpm lint`
##
## For archived runs that techne:audit can reconcile, wrap from OUTSIDE the
## Makefile:
##   ./scripts/dev-runner.sh lint      # writes logs/dev-<UTC>-lint.log
## Do NOT call dev-runner.sh from inside a Makefile recipe — it invokes
## `make` and would recurse.
##
## Help convention: a `## description` comment after the target name drives
## the help target below. Keep descriptions one line.
##

.PHONY: help setup fix lint test test-unit build validate ci audit clean docs dev
.DEFAULT_GOAL := help

setup:                  ## Install project dependencies
	@echo "[setup] TODO: replace with uv sync / npm ci / cargo fetch / pnpm install"; exit 1

fix:                    ## Run every auto-fixer; skip the check pass
	@echo "[fix] TODO: replace with ruff --fix + format / eslint --fix + prettier --write / cargo fmt"; exit 1

lint:                   ## Lint + format check (no auto-fix)
	@echo "[lint] TODO: replace with ruff check + ruff format --check / npm run lint / cargo clippy"; exit 1

test-unit:              ## Unit tests only (fast)
	@echo "[test-unit] TODO: replace with pytest -m 'not slow' / vitest / cargo test --lib"; exit 1

test:                   ## Full test suite
	@echo "[test] TODO: replace with pytest / npm test / cargo test --all"; exit 1

build:                  ## Produce the deployable artifact
	@echo "[build] TODO: replace with uv build / npm run build / cargo build --release"; exit 1

validate: lint test-unit build  ## Fast pre-push gate (lint + unit + build)

ci: lint test build     ## Mirror CI end-to-end

audit:                  ## Security audit
	@echo "[audit] TODO: replace with pip-audit / npm audit / cargo audit"; exit 1

clean:                  ## Remove build artifacts and caches
	@echo "[clean] TODO: replace with rm -rf .ruff_cache build/ dist/ / npm run clean / cargo clean"; exit 1

# Interactive / long-running targets. Mark these under `do_not_run:` in
# .claude/skill-context.md so techne:audit skips them.
docs:                   ## Serve docs site locally (do-not-run)
	@echo "[docs] TODO: replace with uv run zensical serve / npm run docs / etc."; exit 1

dev:                    ## Start dev server (do-not-run)
	@echo "[dev] TODO: replace with uv run dev / npm run dev / cargo run / etc."; exit 1

help:                   ## Show this help
	@grep -hE '^[a-zA-Z][a-zA-Z0-9_-]*:.*?##' $(MAKEFILE_LIST) \
		| sort \
		| awk 'BEGIN {FS = ":.*?## "}; {printf "  %-12s %s\n", $$1, $$2}'
