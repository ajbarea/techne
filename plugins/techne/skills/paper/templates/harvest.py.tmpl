#!/usr/bin/env python3
"""Regenerate figures/eval-table.tex from the __SISTER__ repo (techne:paper harvest).

A paper's result numbers should come from the code, not by hand. Edit CATEGORIES below to
map your paper's claims to the evidence in the source repo, set CORPUS to what you scan,
then run:  python harvest.py   (the paper does \\input{figures/eval-table.tex}).
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

# Source code repo (sibling of papers/). Adjust if your layout differs.
SOURCE = Path(__file__).resolve().parents[2] / "__SISTER__"
CORPUS = SOURCE / "tests"        # what to scan; change to docs/, src/, benchmarks/, ...
OUT = Path(__file__).resolve().parent / "figures" / "eval-table.tex"

# Curated, transparent mapping: claim/property -> regexes matching evidencing files by name.
CATEGORIES: dict[str, list[str]] = {
    "Property A": [r"test_example"],
    # add your paper's claims and the patterns that evidence them
}

_UNIT = re.compile(r"^\s*(?:async\s+)?def\s+test_", re.M)  # the unit you count; adjust


def count(path: Path) -> int:
    return len(_UNIT.findall(path.read_text(encoding="utf-8", errors="ignore")))


def main() -> int:
    if not CORPUS.is_dir():
        sys.exit(f"error: corpus not found at {CORPUS} (set SOURCE/CORPUS for your repo)")
    files = sorted(CORPUS.rglob("*.py"))
    total_f, total_u = len(files), sum(count(p) for p in files)
    rows = []
    for label, pats in CATEGORIES.items():
        pat = re.compile("|".join(pats))
        hits = [p for p in files if pat.search(p.name)]
        rows.append((label, len(hits), sum(count(p) for p in hits)))

    lines = [
        "% AUTO-GENERATED by harvest.py -- do not edit; re-run to refresh.",
        r"\begin{table}[t]\centering",
        r"\caption{Evidence regenerated from the repository by \texttt{harvest.py}.}",
        r"\label{tab:eval}", r"\begin{tabular}{lrr}", r"\toprule",
        r"Claim & Files & Units \\", r"\midrule",
    ]
    lines += [f"{label} & {nf} & {nu} \\\\" for label, nf, nu in rows]
    lines += [
        r"\midrule",
        rf"\textbf{{Total}} & \textbf{{{total_f}}} & \textbf{{{total_u}}} \\",
        r"\bottomrule", r"\end{tabular}", r"\end{table}",
    ]
    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text("\n".join(lines) + "\n", encoding="utf-8")
    print(f"wrote {OUT}: total {total_f} files / {total_u} units")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
